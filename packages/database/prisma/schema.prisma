generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model audit_logs {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?  @db.Uuid
  entity_type String   @db.VarChar(50)
  entity_id   String   @db.Uuid
  action      String   @db.VarChar(50)
  old_values  Json?
  new_values  Json?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  users       users?   @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([entity_type, entity_id], map: "idx_audit_logs_entity")
}

model brands {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String     @unique @db.VarChar(120)
  is_active  Boolean    @default(true)
  created_at DateTime   @default(now()) @db.Timestamptz(6)
  products   products[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cart_items {
  id                    String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cart_id               String                @db.Uuid
  presentation_id       String                @db.Uuid
  quantity              Int
  created_at            DateTime              @default(now()) @db.Timestamptz(6)
  variant_id            String?               @db.Uuid
  carts                 carts                 @relation(fields: [cart_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product_presentations product_presentations @relation(fields: [presentation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product_variants      product_variants?     @relation(fields: [variant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([cart_id, presentation_id])
  @@index([cart_id], map: "idx_cart_items_cart_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model carts {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id String?      @db.Uuid
  user_id     String?      @db.Uuid
  status      String       @db.VarChar(20)
  created_at  DateTime     @default(now()) @db.Timestamptz(6)
  updated_at  DateTime     @default(now()) @db.Timestamptz(6)
  cart_items  cart_items[]
  customers   customers?   @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  users       users?       @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  orders      orders[]
  sales       sales[]

  @@index([customer_id], map: "idx_carts_customer_id")
}

model categories {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String     @unique @db.VarChar(120)
  is_active  Boolean    @default(true)
  created_at DateTime   @default(now()) @db.Timestamptz(6)
  products   products[]
}

model colors {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code             String?            @unique @db.VarChar(30)
  name             String             @unique @db.VarChar(80)
  is_active        Boolean            @default(true)
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  product_variants product_variants[]
}

model customer_addresses {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id  String    @db.Uuid
  label        String?   @db.VarChar(80)
  department   String?   @db.VarChar(120)
  city         String?   @db.VarChar(120)
  district     String?   @db.VarChar(120)
  address_line String
  reference    String?
  is_default   Boolean   @default(false)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  customers    customers @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  orders       orders[]

  @@index([customer_id], map: "idx_customer_addresses_customer_id")
}

model customers {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name          String               @db.VarChar(150)
  phone              String?              @db.VarChar(30)
  email              String?              @db.VarChar(150)
  document_number    String?              @db.VarChar(30)
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  carts              carts[]
  customer_addresses customer_addresses[]
  orders             orders[]
  sales              sales[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model inventory_movements {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stock_unit_id       String              @db.Uuid
  location_id         String              @db.Uuid
  movement_type       String              @db.VarChar(30)
  quantity_units      Int
  reference_type      String?             @db.VarChar(30)
  reference_id        String?             @db.Uuid
  notes               String?
  created_by          String?             @db.Uuid
  created_at          DateTime            @default(now()) @db.Timestamptz(6)
  users               users?              @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  locations           locations           @relation(fields: [location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product_stock_units product_stock_units @relation(fields: [stock_unit_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([location_id], map: "idx_inventory_movements_location_id")
  @@index([reference_type, reference_id], map: "idx_inventory_movements_reference")
  @@index([stock_unit_id], map: "idx_inventory_movements_stock_unit_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model inventory_stock {
  stock_unit_id       String              @db.Uuid
  location_id         String              @db.Uuid
  quantity_units      Int                 @default(0)
  reserved_units      Int                 @default(0)
  min_stock           Int                 @default(0)
  updated_at          DateTime            @default(now()) @db.Timestamptz(6)
  locations           locations           @relation(fields: [location_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product_stock_units product_stock_units @relation(fields: [stock_unit_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([stock_unit_id, location_id])
  @@index([location_id], map: "idx_inventory_stock_location_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model locations {
