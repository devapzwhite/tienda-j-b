{
  "name": "tienda-j-b",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "dev": "pnpm --parallel -r run dev",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter database exec prisma generate",
    "db:pull": "pnpm --filter database exec prisma db pull",
    "db:migrate": "pnpm --filter database exec prisma migrate dev"
  },
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": "22.13.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "bcrypt",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
